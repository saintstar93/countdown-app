{
  "expo": {
    "name": "Nearday",
    "slug": "nearday",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nearday",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nearday.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Nearday ha bisogno di accedere alla tua galleria per caricare foto negli eventi.",
        "NSCameraUsageDescription": "Nearday ha bisogno della fotocamera per scattare foto per i tuoi eventi.",
        "NSCalendarsUsageDescription": "Nearday ha bisogno di accedere al calendario per esportare i tuoi eventi.",
        "NSUserNotificationUsageDescription": "Nearday invia notifiche per ricordarti i tuoi eventi in arrivo."
      }
    },
    "android": {
      "package": "com.nearday.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E8754A",
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Nearday accede alla tua galleria per aggiungere immagini agli eventi."
        }
      ],
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "Nearday ha bisogno di accedere al calendario per esportare i tuoi eventi."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa57bda9-68fc-4e58-919e-ac91b1da0b27"
      }
    },
    "owner": "kamiwaza93"
  }
}
