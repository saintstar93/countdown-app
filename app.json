{
  "expo": {
    "name": "Nearday",
    "slug": "nearday",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nearday",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "privacyPolicyUrl": "https://saintstar93.github.io/nearday/privacy.html",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nearday.app"
    },
    "android": {
      "package": "com.nearday.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Nearday accede alla tua galleria per aggiungere immagini agli eventi."
        }
      ],
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "L'app accede al calendario per salvare gli eventi."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/nearday/"
    }
  }
}
